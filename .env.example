# Copy this file to .env (or .env.local for dev) and fill in real values.
# Never commit a file containing real secrets.

# ── MySQL ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=wallethub_app
DB_PASSWORD=replace-me
DB_NAME=wallethub
# Set to "true" if your managed MySQL provider requires TLS (PlanetScale, RDS, etc.)
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-random-string-of-at-least-32-chars
JWT_EXPIRES_IN=7d

# ── Google Sign-In ────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Authorized JavaScript origins must include your production domain.
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Gemini (Google AI Studio) ─────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
